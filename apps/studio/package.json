{
  "name": "@gsd/studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && cp -r src/resources dist/",
    "preview": "npm run build && electron-vite preview",
    "test:main": "node --import tsx/esm --test test/**/*.test.{ts,mjs}",
    "test:renderer": "vitest --run",
    "test:all": "npm run test:main && npm run test:renderer",
    "test:coverage": "vitest --coverage",
    "test:smoke": "node --import tsx/esm --test test/**/*.smoke.test.ts",
    "build:pwa": "vite build --config vite.pwa.config.ts",
    "serve:pwa": "vite preview --config vite.pwa.config.ts",
    "serve": "tsx src/main/server.ts",
    "bundle-audio-service": "node scripts/build-audio-runtime.cjs",
    "bundle-audio-service:none": "LUCENT_INCLUDE_AUDIO_SERVICE=0 node scripts/build-audio-runtime.cjs",
    "prebundle-runtime": "npm run build -w @gsd/pi-coding-agent",
    "bundle-runtime": "npm run bundle -w @gsd/pi-coding-agent",
    "bundle-runtime:force": "npm run bundle -w @gsd/pi-coding-agent -- -- --force",
    "pack": "SKIP_NOTARIZE=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run bundle-audio-service && npm run bundle-runtime && electron-builder --dir --config.mac.identity=null",
    "pack:arm64": "SKIP_NOTARIZE=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder --dir --arm64 --config.mac.identity=null",
    "dist": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -wml",
    "dist:mac": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -m",
    "dist:mac:arm64": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -m --arm64",
    "dist:mac:x64": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -m --x64",
    "dist:mac:universal": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -m --universal",
    "release": "npm run build && npm run bundle-audio-service && npm run bundle-runtime && electron-builder -m --publish never",
    "release:arm64": "node scripts/release.cjs",
    "release:arm64:no-audio": "node scripts/release.cjs --without-audio",
    "release:arm64:notarize": "node scripts/release.cjs --notarize",
    "release:arm64:dry": "node scripts/release.cjs --dry-run",
    "release:arm64:no-audio:dry": "node scripts/release.cjs --dry-run --without-audio"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "ws": "^8.18.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "4.1.2",
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "happy-dom": "20.8.9",
    "jsdom": "29.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.1.2"
  },
  "build": {
    "appId": "com.lucent.code",
    "productName": "Lucent Code",
    "electronVersion": "41.0.3",
    "afterSign": "notarize.cjs",
    "publish": {
      "provider": "github",
      "owner": "lucentcode",
      "repo": "lucent-code"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../packages/pi-coding-agent/bundle",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/audio-service-bundle",
        "to": "audio-service",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "identity": "Tuan Son Dinh (34UMY69QMK)",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app needs microphone access for voice input.",
        "NSCameraUsageDescription": "This app does not access your camera.",
        "NSSupportsAutomaticTermination": false,
        "NSRequiresAquaSystemAppearance": false
      },
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Lucent Code",
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
