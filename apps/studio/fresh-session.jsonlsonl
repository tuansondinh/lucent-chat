s/sonwork/Workspace/voice-bridge-desktop/dist/resources/extensions/subagent/index.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/resources/extensions/browser-tools/tools/codegen.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/resources/extensions/browser-tools/tools/network-mock.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/headless.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/headless-events.d.ts\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/logo.d.ts\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/mcp-server.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/headless-events.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/update-check.d.ts\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/headless-ui.js\n/Users/sonwork/Workspace/voice-bridge-desktop/dist/cli.js\n"}],"isError":false,"timestamp":1774733281322}}
