<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for microphone access in voice mode -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- Required for Electron renderer process (JIT compilation) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for unsigned code execution (Electron internals) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for DYLD injection used by Electron dev tools -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
