{
  "name": "@lc/studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "node --test test/*.test.mjs",
    "build:pwa": "vite build --config vite.pwa.config.ts",
    "serve:pwa": "vite preview --config vite.pwa.config.ts",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder -wml",
    "dist:mac": "npm run build && electron-builder -m",
    "dist:mac:arm64": "npm run build && electron-builder -m --arm64",
    "dist:mac:x64": "npm run build && electron-builder -m --x64",
    "dist:mac:universal": "npm run build && electron-builder -m --universal",
    "release": "npm run build && electron-builder -m --publish never"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "qrcode.react": "^4.2.0",
    "ws": "^8.18.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.lucent.chat",
    "productName": "Lucent Chat",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "audio-service/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "entitlementsFile": "entitlements.mac.plist",
      "entitlementsInheritFile": "entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app needs microphone access for voice input.",
        "NSCameraUsageDescription": "This app does not access your camera.",
        "NSSupportsAutomaticTermination": false,
        "NSRequiresAquaSystemAppearance": false
      },
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Lucent Chat",
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
